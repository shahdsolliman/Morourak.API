{
  

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  "ConnectionStrings": {
    "IdentityConnection": "ENV_IDENTITY_CONNECTION_STRING",
    "PersistenceConnection": "ENV_PERSISTENCE_CONNECTION_STRING"
  },

  "Jwt": {
    "Key": "ENV_JWT_KEY",
    "Issuer": "Morourak.API",
    "Audience": "Morourak.Client",
    "DurationInMinutes": 60
  },

  "EmailSettings": {
    "SmtpServer": "smtp.gmail.com",
    "Port": 587,
    "EnableSSL": true,
    "UserName": "ENV_EMAIL_USERNAME",
    "Password": "ENV_EMAIL_PASSWORD"
  },

  "PayMob": {
    "ApiKey": "ENV_PAYMOB_API_KEY",
    "IframeId": 0,
    "IntegrationId": "ENV_PAYMOB_INTEGRATION_ID",
    "HmacSecret": "ENV_PAYMOB_HMAC_SECRET",
    "BaseUrl": "https://accept.paymob.com/api/"
  }
}
